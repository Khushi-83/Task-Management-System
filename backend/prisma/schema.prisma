generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String     @id @default(uuid())
  name       String
  email      String     @unique
  password   String
  created_at DateTime   @default(now())
  tasks      Task[]
  feedbacks  Feedback[]
}

model Task {
  id          String        @id @default(uuid())
  user_id     String
  user        User          @relation(fields: [user_id], references: [id])
  title       String
  description String?
  priority    Priority      @default(MEDIUM)
  status      Status        @default(PENDING)
  due_date    DateTime?
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt
  history     TaskHistory[]
  feedbacks   Feedback[]

  @@index([user_id])
  @@index([updated_at])
}

model TaskHistory {
  id             String     @id @default(uuid())
  task_id        String
  task           Task       @relation(fields: [task_id], references: [id], onDelete: Cascade)
  action_type    ActionType
  previous_state Json?
  timestamp      DateTime   @default(now())

  @@index([task_id])
}

model Feedback {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  task_id    String?
  task       Task?    @relation(fields: [task_id], references: [id], onDelete: SetNull)
  comment    String
  rating     Int
  created_at DateTime @default(now())
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Status {
  PENDING
  COMPLETED
  ARCHIVED
}

enum ActionType {
  CREATED
  UPDATED
  COMPLETED
  DELETED
}
